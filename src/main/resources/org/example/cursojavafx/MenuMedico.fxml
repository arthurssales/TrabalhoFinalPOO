<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #FFF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.cursojavafx.controller.MenuMedicoController">

    <children>

        <VBox prefHeight="50.0" prefWidth="800.0" style="-fx-background-color: #000000;" />

        <ImageView fitHeight="100.0" fitWidth="150.0" layoutX="250.0" layoutY="51.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../../imagem/Logo.png" />
            </image>
        </ImageView>

        <Label layoutX="350.0" layoutY="63.0" text="Seja bem vindo, Dr(a).">
            <font><Font name="Century Gothic" size="18.0" /></font>
        </Label>
        <Label fx:id="nomeMedico" layoutX="555.0" layoutY="63.0" prefWidth="180.0" text="Nome">
            <font><Font name="Century Gothic" size="18.0" /></font>
        </Label>

        <Pane layoutY="50.0" prefHeight="550.0" prefWidth="250.0" style="-fx-background-color: #6fc5dd;">
            <children>

                <Button fx:id="botaoSair" layoutX="14.0" layoutY="461.0" mnemonicParsing="false" onAction="#sair" prefHeight="39.0" prefWidth="140.0" style="-fx-background-color: #000000; -fx-background-radius: 100;" text="Sair" textFill="WHITE">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                    <graphic>
                        <ImageView fitHeight="30.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../../../imagem/PortaSair.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>
        </Pane>

        <!-- ===== Cards de ação na área central ===== -->

        <!-- Consultas marcadas -->
        <Label layoutX="342.0" layoutY="190.0" text="Consultas marcadas">
            <font><Font name="Century Gothic" size="18.0" /></font>
        </Label>

        <!-- Consultas realizadas -->
        <Label layoutX="596.0" layoutY="191.0" text="Consultas realizadas">
            <font><Font name="Century Gothic" size="18.0" /></font>
        </Label>

        <!-- Contador de consultas realizadas -->
        <Label fx:id="labelQtdConsultas" layoutX="620.0" layoutY="226.0" prefHeight="39.0" prefWidth="115.0" style="-fx-text-fill: #555;" text="0 consultas">
            <font><Font name="Britannic Bold" size="17.0" /></font>
        </Label>

        <!-- Avaliação média -->
        <Label layoutX="290.0" layoutY="398.0" prefHeight="60.0" prefWidth="219.0" text="Minha avaliação">
            <font><Font name="Century Gothic" size="18.0" /></font>
            <graphic>
                <Button fx:id="botaoAvaliacao" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #FFF;">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
            </graphic>
        </Label>

        <!-- Label da avaliação média -->
        <Label fx:id="labelAvaliacaoMedia" layoutX="290.0" layoutY="478.0" style="-fx-text-fill: #555;" text="Média: --">
            <font><Font name="Century Gothic" size="14.0" /></font>
        </Label>
        <Button fx:id="botaoConsultas" layoutX="275.0" layoutY="172.0" mnemonicParsing="false" onAction="#verConsultas" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #CFF;">
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
            <graphic>
                <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true">
                    <image>
                        <Image url="@../../../imagem/Calendario.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>

        <Button fx:id="botaoConsultasRealizadas" layoutX="536.0" layoutY="172.0" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: #CFF;">
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
            <graphic>
                <ImageView fitHeight="50.0" fitWidth="42.0" pickOnBounds="true">
                    <image>
                        <Image url="@../../../imagem/Prancheta.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
      <Label layoutX="275.0" layoutY="281.0" text="Realizar consulta">
         <font>
            <Font name="Century Gothic" size="18.0" />
         </font>
         <graphic>
            <Button fx:id="botaoRealizaConsulta" mnemonicParsing="false" onAction="#realizarConsulta" prefHeight="60.0" prefWidth="60.0" />
         </graphic>
      </Label>

    </children>
</AnchorPane>
