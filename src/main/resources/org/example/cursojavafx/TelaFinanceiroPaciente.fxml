<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #FFF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.cursojavafx.controller.FinanceiroPacienteController">

    <children>

        <VBox prefHeight="50.0" prefWidth="800.0" style="-fx-background-color: #000000;" />

        <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="251.0" layoutY="51.0" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@../../../imagem/Logo.png" /></image>
        </ImageView>

        <Pane layoutY="50.0" prefHeight="550.0" prefWidth="250.0" style="-fx-background-color: #6fc5dd;">
            <children>
                <Button fx:id="botaoVoltar" layoutX="14.0" layoutY="461.0" mnemonicParsing="false" onAction="#voltar" prefHeight="39.0" prefWidth="140.0" style="-fx-background-color: #000000; -fx-background-radius: 100;" text="Voltar" textFill="WHITE">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                    <graphic>
                        <ImageView fitHeight="30.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../../../imagem/PortaSair.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
        </Pane>

        <Label layoutX="408.0" layoutY="81.0" text="Financeiro">
            <font><Font name="Century Gothic" size="22.0" /></font>
        </Label>

        <Pane layoutX="290.0" layoutY="150.0" prefHeight="120.0" prefWidth="220.0" style="-fx-background-color: #eaf8fc; -fx-border-color: #6fc5dd; -fx-border-radius: 10; -fx-background-radius: 10;">
            <children>
                <Label layoutX="15.0" layoutY="15.0" text="Plano ativo">
                    <font><Font name="Century Gothic" size="13.0" /></font>
                </Label>
                <Label fx:id="custoPlano" layoutX="15.0" layoutY="45.0" text="--">
                    <font><Font name="Century Gothic" size="20.0" /></font>
                </Label>
                <Label fx:id="custoConsultas" layoutX="15.0" layoutY="78.0" style="-fx-text-fill: #555;" text="R$ -- por consulta">
                    <font><Font name="Century Gothic" size="13.0" /></font>
                </Label>
            </children>
        </Pane>

        <!-- Card: Custo total -->
        <Pane layoutX="540.0" layoutY="150.0" prefHeight="120.0" prefWidth="220.0" style="-fx-background-color: #eaf8fc; -fx-border-color: #6fc5dd; -fx-border-radius: 10; -fx-background-radius: 10;">
            <children>
                <Label layoutX="15.0" layoutY="15.0" text="Total gasto">
                    <font><Font name="Century Gothic" size="13.0" /></font>
                </Label>
                <Label fx:id="custoTotal" layoutX="15.0" layoutY="45.0" text="R$ 0,00">
                    <font><Font name="Century Gothic" size="20.0" /></font>
                </Label>
            </children>
        </Pane>

        <!-- Seção: Simular consulta -->
        <Label layoutX="290.0" layoutY="310.0" text="Simular valor de consulta">
            <font><Font name="Century Gothic" size="16.0" /></font>
        </Label>

        <ComboBox fx:id="comboTipoMedico" layoutX="290.0" layoutY="345.0" onAction="#calcularValor" prefWidth="220.0" promptText="Selecione o tipo de médico" style="-fx-background-color: #eaf8fc; -fx-border-color: #6fc5dd; -fx-border-radius: 5;" />

        <Label fx:id="labelValorConsulta" layoutX="290.0" layoutY="400.0" style="-fx-text-fill: #222;" text="">
            <font><Font name="Century Gothic" size="18.0" /></font>
        </Label>

        <Label fx:id="labelAvisoPlano" layoutX="290.0" layoutY="435.0" style="-fx-text-fill: #e05;" text="">
            <font><Font name="Century Gothic" size="12.0" /></font>
        </Label>

    </children>
</AnchorPane>
