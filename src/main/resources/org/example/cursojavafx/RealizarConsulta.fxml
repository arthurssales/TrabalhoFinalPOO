<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.example.cursojavafx.controller.RealizarConsultaController">

    <Label fx:id="lblPaciente"/>
    <Label fx:id="lblData"/>

    <Label text="Sintomas"/>
    <TextArea fx:id="txtSintomas"/>

    <Label text="Diagnóstico"/>
    <TextArea fx:id="txtDiagnostico"/>

    <Label text="Tratamento"/>
    <TextArea fx:id="txtTratamento"/>

    <Label text="Medicamentos"/>
    <TextArea fx:id="txtMedicamentos"/>

    <Label text="Exames"/>
    <TextArea fx:id="txtExames"/>

    <Label text="Observações"/>
    <TextArea fx:id="txtObservacoes"/>

    <Button text="Finalizar Consulta"
            onAction="#finalizarConsulta"/>

</VBox>